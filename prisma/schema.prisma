generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         Role      @default(USER)
  bookings     Booking[]
  createdAt    DateTime  @default(now())
}

model Category {
  id     String  @id @default(cuid())
  name   String  @unique
  slug   String  @unique
  events Event[]
}

model Event {
  id          String    @id @default(cuid())
  title       String
  description String
  date        DateTime
  location    String
  capacity    Int
  imageUrl    String?
  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id])
  bookings    Booking[]
  createdAt   DateTime  @default(now())
}

model Booking {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  eventId   String
  event     Event         @relation(fields: [eventId], references: [id])
  status    BookingStatus @default(CONFIRMED)
  createdAt DateTime      @default(now())

  @@unique([userId, eventId])
}

enum Role {
  USER
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED
}
